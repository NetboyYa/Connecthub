{
  "expo": "49.0.0",
  "name": "connecthub",
  "slug": "connecthub",
  "version": "1.0.0",
  "assetBundlePatterns": ["**/*"],
  "ios": {
    "supportsTablet": true,
    "bundleIdentifier": "com.connecthub.app",
    "buildNumber": "1.0.0"
  },
  "android": {
    "adaptiveIcon": {
      "foregroundImage": "./assets/adaptive-icon.png",
      "backgroundColor": "#1a1a2e"
    },
    "package": "com.connecthub.app",
    "versionCode": 1,
    "usesCleartextTraffic": false
  },
  "web": {
    "favicon": "./assets/favicon.png",
    "bundler": "metro"
  },
  "plugins": [
    [
      "expo-build-properties",
      {
        "ios": {
          "useFrameworks": "static"
        }
      }
    ]
  ],
  "scheme": "connecthub",
  "platforms": ["ios", "android", "web"]
}